{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.(t|j)s"],
  "coverageDirectory": "../coverage",
  "testTimeout": 30000,
  "setupFiles": ["<rootDir>/test/setup.ts"],
  "globals": {
    "ts-jest": {
      "tsconfig": {
        "types": ["jest", "node"]
      }
    }
  }
}
