# Server
PORT=5004

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=invoice_db

# Kafka — same broker as berthing_service
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=invoice-service-group
KAFKA_CLIENT_ID=invoice-service

# Berthing Service URL — used to fetch allocation details after Kafka events
# The Kafka wire only carries vesselID, so we call the HTTP API for the rest
BERTHING_SERVICE_URL=http://localhost:5003

# Tariff Rates (USD)
TARIFF_BERTH_PER_HOUR=150.00
TARIFF_YARD_PER_CONTAINER_PER_HOUR=12.00
TARIFF_PENALTY_PER_HOUR=300.00
TARIFF_PORT_FEE=500.00


